<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= company ? company.name : 'Company' %> | Issues</title>
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/job.css">
    <script defer src="/js/job.js"></script>
    <script defer src="/js/searchJobs.js"></script>
    <style>
      #job-search-input::placeholder {
        color: var(--bpColor);
        opacity: 0.7;
      }
    </style>
    <link rel="icon" href="/icons/jobbar.png">
</head>

<body>
  <%- include("banner.ejs") %>
  <main class="jobs-container">
    <% 
      // compute owner-based permissions and precompute URLs server-side
      const ownerId = company && (company.owner_id !== undefined && company.owner_id !== null) ? String(company.owner_id) : null;
      const requesterId = typeof fb_id !== 'undefined' && fb_id !== null ? String(fb_id) : null;
      const canManage = requesterId && ownerId && requesterId === ownerId;
      const jobPostsUrl = company ? ('/jobPosts/' + encodeURIComponent(company.name)) : '/jobPosts/Not%20found';
      const jobManagerUrl = company ? ('/jobManager/' + encodeURIComponent(company.name)) : '/jobManager/Not%20found';
    %>
    <div class="nav-row">
      <% if (canManage) { %>
        <a class="small-btn" href="<%= jobPostsUrl %>">+ Add Contract</a>
        <button class="small-btn" onclick="location.href='<%= jobManagerUrl %>'">Manage Contracts</button>
      <% } %>
      <input id="job-search-input" type="text" placeholder="Search jobs..." style="margin: 0;"/>
    </div>

    <section aria-labelledby="jobs-list">
      <% 
        // Filter for available jobs (status === 'available')
        const availableJobs = jobs ? jobs.filter(job => {
          return job && job.status && String(job.status).toLowerCase() === 'available';
        }) : [];
      %>
      %>
      
      <% if (availableJobs.length === 0) { %>
        <p>No jobs available for this company.</p>
      <% } else { %>
        <div class="jobs-grid">
          <% availableJobs.forEach(function(job){ %>
            <article class="job-card" role="article">
              <div class="job-title"><%= job.title %></div>
              <div class="job-desc"><%= job.description %></div>
              <div class="job-link">
                            <a href="<%= job.link %>" target="_blank">
                                <img src="/icons/redirect.png" width="15" height="15">
                                <div class="text">Visit Contract Source</div>
                            </a>
                        </div>
              <div class="job-pay" style="display: flex; gap: 5px; align-items: center; justify-content: center;">
                +<img src="/icons/cost.png" width="20" height="20" style="filter: invert(1);">
                <div><%= job.pay %></div>
              </div>
              <div style="margin-top:0.6rem; display: flex; justify-content: center;">
                <% if (job.you_applied) { %>
                  <span class="job-meta taken">You applied</span>
                <% } else { %>
                  <form action="/job/<%= job.id %>/apply" method="POST" style="display:inline">
                      <button type="submit" class="apply-btn">
                          Apply
                      </button>
                  </form>
                <% } %>
                
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>
  <script>
    document.addEventListener('DOMContentLoaded', function(){
      if (window.jobSearchInit) window.jobSearchInit('job-search-input');
    });
  </script>
</body>

</html>